# Bybit API Configuration
BYBIT_API_BASE=https://api.bybit.com

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Pushover Notification Configuration (optional backup alerts)
PUSHOVER_TOKEN=your_pushover_app_token_here
PUSHOVER_USER=your_pushover_user_key_here

# Application Settings
SYMBOL_REFRESH_INTERVAL_MS=900000  # 15 minutes
OI_FETCH_INTERVAL_MS=60000         # 60 seconds
ALERT_COOLDOWN_MINUTES=10          # 10 minutes between alerts per symbol
CASCADE_WINDOW_MINUTES=30          # Minutes to detect BUILDUP→LIQUIDATION sequence
CONCURRENT_FETCHES=20              # Number of parallel OI fetches
